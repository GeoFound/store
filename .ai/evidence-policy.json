{
  "version": "1.0.0",
  "reportDirectory": ".ai-trace/evidence",
  "defaultChecks": [
    {
      "id": "ai-doctor",
      "command": ["pnpm", "ai:doctor"],
      "required": true
    },
    {
      "id": "ai-architecture",
      "command": ["pnpm", "ai:architecture"],
      "required": true
    },
    {
      "id": "ai-config",
      "command": ["pnpm", "ai:config"],
      "required": true
    },
    {
      "id": "ai-inventory",
      "command": ["pnpm", "ai:inventory"],
      "required": true
    },
    {
      "id": "ai-production",
      "command": ["pnpm", "ai:production"],
      "required": true
    },
    {
      "id": "ai-status",
      "command": ["pnpm", "ai:status"],
      "required": true
    },
    {
      "id": "git-status",
      "command": ["git", "status", "--short"],
      "required": true,
      "allowOutput": true
    }
  ],
  "fullChecks": [
    {
      "id": "ci",
      "command": ["pnpm", "check:ci"],
      "required": true
    },
    {
      "id": "profile-validate-all",
      "command": ["pnpm", "profile:validate:all"],
      "required": true
    },
    {
      "id": "site-validate-all",
      "command": ["pnpm", "site:validate:all"],
      "required": true
    }
  ],
  "productionChecks": [
    {
      "id": "deploy-health",
      "command": ["pnpm", "deploy:health"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-dns",
      "command": ["pnpm", "deploy:dns"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-edge",
      "command": ["pnpm", "deploy:edge"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-waf",
      "command": ["pnpm", "deploy:waf"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-admin-edge",
      "command": ["pnpm", "deploy:admin-edge"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-rate-limit",
      "command": ["pnpm", "deploy:rate-limit"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-regression",
      "command": ["pnpm", "deploy:regression"],
      "requiresRuntime": true
    },
    {
      "id": "deploy-vps-doctor",
      "command": ["pnpm", "deploy:vps-doctor"],
      "requiresRuntime": true
    }
  ],
  "acceptanceRules": [
    "A task is not complete just because prose was updated.",
    "If a check cannot run, the evidence report must say why and what external action is needed.",
    "Human approval is a decision input, not a substitute for runtime evidence."
  ]
}
