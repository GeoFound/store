{
  "version": "1.0.0",
  "repository": {
    "name": "single-store-digital-goods",
    "role": "engineering-system",
    "goal": "Build, verify, deploy, and continuously evolve the product with AI-first automation.",
    "packageManager": "pnpm@10.32.1",
    "node": ">=22"
  },
  "product": {
    "name": "independent-digital-goods-store",
    "role": "implemented-product",
    "goal": "A production-grade single-store digital goods storefront with payment, inventory, delivery, recovery, audit, supplier procurement, marketing, analytics, and multi-site deployment support.",
    "primarySpec": "docs/independent-store-spec.md"
  },
  "operatingModel": {
    "humanRole": [
      "business direction",
      "risk acceptance",
      "vendor/provider selection",
      "legal/compliance text",
      "domain, production credentials, and irreversible deployment decisions"
    ],
    "aiRole": [
      "implementation",
      "maintenance",
      "refactoring",
      "test and fixture creation",
      "evidence generation",
      "production-readiness checks",
      "risk surfacing with concrete recommendations"
    ],
    "conversationPolicy": {
      "humanDecisionsHappenInChat": true,
      "askOnlyForDecisionOrExternalAction": true,
      "whenAskingHuman": [
        "state exact action needed",
        "state why automation cannot complete it",
        "state expected evidence after completion",
        "offer 1 to 3 concrete options when it is a decision"
      ]
    }
  },
  "evidencePolicy": {
    "priority": [
      "real runtime result",
      "automated test result",
      "static validation result",
      "source inspection",
      "human statement"
    ],
    "humanReviewIsAcceptance": false,
    "requiredForProduction": [
      "pnpm ai:production",
      "pnpm check:ci",
      "pnpm profile:validate:all",
      "pnpm deploy:health",
      "pnpm deploy:dns",
      "pnpm deploy:edge",
      "pnpm deploy:waf",
      "pnpm deploy:admin-edge",
      "pnpm deploy:rate-limit",
      "pnpm deploy:regression",
      "pnpm deploy:vps-doctor",
      "backup and rollback evidence"
    ],
    "failurePrinciple": "Anything that may be wrong should fail as early as practical."
  },
  "decisionGates": [
    {
      "id": "business-direction",
      "requiresHuman": true,
      "examples": ["new product line", "new market", "pricing model", "user promise change"]
    },
    {
      "id": "production-risk",
      "requiresHuman": true,
      "examples": ["go-live", "rollback", "data migration with irreversible effects", "payment provider launch"]
    },
    {
      "id": "external-secret-or-account",
      "requiresHuman": true,
      "examples": ["API keys", "domain DNS", "provider account approval", "legal documents"]
    },
    {
      "id": "routine-engineering",
      "requiresHuman": false,
      "examples": ["tests", "refactors", "bug fixes", "automation", "docs for machine context"]
    }
  ],
  "architectureBoundaries": {
    "backendPlatformCore": {
      "path": "apps/backend/src/platform",
      "mustNotContain": ["@medusajs/", "../modules/", "../../modules/", "../platform-adapters/", "../../platform-adapters/"]
    },
    "backendAdapters": {
      "path": "apps/backend/src/platform-adapters",
      "role": "Medusa/module binding layer for built-ins and runtime bootstrap"
    },
    "storefrontCommercePort": {
      "path": "apps/storefront/src/lib/commerce.ts",
      "role": "backend-neutral commerce API for UI code"
    }
  },
  "coldStart": {
    "readFirst": [
      ".ai/system.json",
      ".ai/system-map.json",
      ".ai/taskbook.json",
      ".ai/evidence-policy.json",
      ".ai/obligations-policy.json",
      ".ai/architecture-rules.json",
      ".ai/architecture-baseline.json",
      ".ai/config-surface.json",
      ".ai/admin-control-panel-policy.json",
      ".ai/production-readiness.json",
      ".ai/site-lifecycle-policy.json",
      ".ai/inventory-baseline.json",
      ".ai/skills/store-ai-maintainer/SKILL.md",
      ".ai/decision-records",
      ".ai/review-checklists",
      "docs/architecture/decoupling-boundaries.md",
      "docs/ops/production-runbook.md",
      "docs/ops/site-lifecycle.md"
    ],
    "runFirst": ["pnpm ai:context", "pnpm ai:doctor", "pnpm ai:architecture", "pnpm ai:inventory", "pnpm ai:obligations", "pnpm ai:config", "pnpm ai:production"],
    "runBeforeCommit": ["pnpm check:ci"],
    "runBeforeProduction": ["pnpm ai:evidence:full"]
  },
  "automation": {
    "requiredPackageScripts": [
      "ai:context",
      "ai:architecture",
      "ai:config",
      "ai:inventory",
      "ai:obligations",
      "ai:production",
      "ai:doctor",
      "ai:status",
      "ai:evidence",
      "ai:evidence:full",
      "check:ci",
      "profile:validate:all",
      "site:validate",
      "site:validate:all",
      "site:evidence",
      "site:evidence:all",
      "site:gate",
      "deploy:health",
      "deploy:dns",
      "deploy:edge",
      "deploy:waf",
      "deploy:admin-edge",
      "deploy:rate-limit",
      "deploy:regression",
      "deploy:vps-doctor",
      "backup:db",
      "backup:restore-drill",
      "restore:db",
      "secrets:rotate"
    ]
  }
}
