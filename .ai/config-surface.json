{
  "version": "1.0.0",
  "principles": [
    "Every runtime configuration key read by application code must be registered here.",
    "Public storefront configuration must never control backend capabilities.",
    "Tenant identity and deployment mode are first-class configuration boundaries.",
    "Production safety-critical configuration must fail before serving traffic."
  ],
  "scan": {
    "sourceRoots": ["apps/backend/src", "apps/storefront/src"],
    "ignorePathSegments": ["/migrations/", "/.medusa/", "/dist/", "/__tests__/", ".test.", ".spec."],
    "allowedDynamicPatterns": [
      {
        "pattern": "^SECURITY_LIMIT_[A-Z0-9_]+_(MAX_REQUESTS|WINDOW_SECONDS|BLOCK_SECONDS)$",
        "owner": "security-guard",
        "scope": "backend",
        "rationale": "Per-route rate limit policies are generated from explicit SECURITY_LIMIT_* prefixes in middleware configuration.",
        "verification": ["pnpm ai:config", "pnpm --dir apps/backend test:unit"]
      }
    ],
    "allowedDynamicAccess": [
      {
        "path": "apps/backend/src/utils/security-rate-limit.ts",
        "owner": "security-guard",
        "rationale": "Reads SECURITY_LIMIT_* keys derived from caller-provided route policy prefixes; allowed keys are constrained by allowedDynamicPatterns.",
        "verification": ["pnpm ai:config", "pnpm --dir apps/backend test:unit"]
      },
      {
        "path": "apps/backend/src/utils/runtime-secrets.ts",
        "owner": "config-surface",
        "rationale": "Generic secret helper reads caller-provided registered key names and fallback names; concrete runtime keys remain registered in entries.",
        "verification": ["pnpm ai:config", "pnpm check:ci"]
      },
      {
        "path": "apps/backend/src/modules/ai-core/config.ts",
        "owner": "ai-core",
        "rationale": "AI provider configs reference arbitrary deployment-owned secret env names through api_key_env; the module only checks presence and never returns secret values.",
        "verification": ["pnpm ai:config", "pnpm --dir apps/backend test:unit"]
      },
      {
        "path": "apps/backend/src/modules/ops-control/service.ts",
        "owner": "ops-control",
        "rationale": "Ops-control renders a registered settings catalog through shared helpers; dynamic access is limited to keys declared in .ai/config-surface.json and never returns secret values.",
        "verification": ["pnpm ai:config", "pnpm --dir apps/backend test:unit"]
      }
    ]
  },
  "entries": {
