{
  "id": "routine-change",
  "title": "Routine AI implementation checklist",
  "scope": "bug fix, small feature, refactor, or test update",
  "execution": {
    "mode": "guidance",
    "commandsAreRunBy": [".ai/evidence-policy.json", ".ai/taskbook.json", "package.json"]
  },
  "items": [
    {
      "id": "worktree-known",
      "checkType": "command",
      "command": ["git", "status", "--short"],
      "evidenceRequired": "Worktree state inspected before and after edits."
    },
    {
      "id": "focused-tests",
      "checkType": "command",
      "command": ["pnpm", "check:ci"],
      "evidenceRequired": "Relevant automated checks passed."
    },
    {
      "id": "machine-context-current",
      "checkType": "command",
      "command": ["pnpm", "ai:doctor"],
      "evidenceRequired": "AI governance and boundary checks passed."
    },
    {
      "id": "surface-and-debt-gates",
      "checkType": "command",
      "command": ["pnpm", "ai:evidence"],
      "evidenceRequired": "Architecture baseline, inventory baseline, config surface, production readiness, status, and git state were captured."
    }
  ],
  "humanGate": false
}
