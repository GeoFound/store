@@ -31,3 +36,44 @@ export const I18n = () => {
 }
 
 export { i18n }
+
+type TranslationResource = {
+  translation?: Record<string, unknown>
+}
+
+function mergeTranslationResources(
+  primary?: TranslationResource,
+  override?: TranslationResource
+): TranslationResource {
+  return {
+    ...primary,
+    ...override,
+    translation: deepMergeObjects(primary?.translation, override?.translation),
+  }
+}
+
+function deepMergeObjects(
+  primary?: Record<string, unknown>,
+  override?: Record<string, unknown>
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {
+    ...(primary || {}),
+  }
+
+  for (const [key, value] of Object.entries(override || {})) {
+    const existing = result[key]
+
+    if (isPlainObject(existing) && isPlainObject(value)) {
+      result[key] = deepMergeObjects(existing, value)
+      continue
+    }
+
+    result[key] = value
+  }
+
+  return result
+}
+
+function isPlainObject(value: unknown): value is Record<string, unknown> {
+  return !!value && typeof value === "object" && !Array.isArray(value)
+}
