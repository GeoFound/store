{
  "site": {
    "id": "jp-cards",
    "name": "Shiro Keys Staging",
    "description": "Staging environment for Japan-market digital cards and account stock",
    "locale": "ja-JP",
    "currency": "jpy",
    "timezone": "Asia/Tokyo"
  },
  "domains": {
    "storefront": "staging.jp.example.com",
    "api": "api.staging.jp.example.com"
  },
  "tenancy": {
    "mode": "dedicated",
    "data_plane": "isolated",
    "control_plane": "profile"
  },
  "lifecycle": {
    "site_launch_contract_version": "1.0.0",
    "environment": "staging",
    "data_policy": {
      "real_user_data_allowed": false,
      "production_real_tenant_evidence_allowed": false,
      "graph_mode": "dry_run",
      "graph_production_write_enabled": false,
      "analytics_export_mode": "dry_run",
      "payment_mode": "test",
      "supplier_auto_procurement_enabled": false
    },
    "controls": {
      "staging_required": true,
      "cloudflare_required": true,
      "runtime_health_required": true,
      "edge_preflight_required": true,
      "regression_required": true,
      "backup_required": true,
      "restore_test_required": true,
      "rollback_required": true,
      "human_gate_required": false
    },
    "evidence": {
      "required_static_commands": ["pnpm check:ci", "pnpm profile:validate:all", "pnpm site:validate:all"],
      "required_runtime_commands": ["pnpm deploy:health", "pnpm deploy:edge", "pnpm deploy:regression", "pnpm deploy:vps-doctor"],
      "last_runtime_health_ref": null,
      "last_edge_preflight_ref": null,
      "last_regression_ref": null,
      "last_backup_ref": null,
      "last_restore_test_ref": null,
      "last_rollback_ref": null,
      "last_staging_evidence_ref": null,
      "human_gate_ref": null
    }
  },
  "theme": {
    "id": "shiro-cards",
    "background": "#faf7f2",
    "foreground": "#111827",
    "accent": "#be123c",
    "accent_secondary": "#0f766e",
    "surface": "#ffffff",
    "surface_muted": "#fff1f2",
    "border": "#e7e5e4",
    "success": "#0f766e",
    "danger": "#be123c",
    "warning": "#b45309",
    "radius": "6px",
    "density": "compact"
  },
