  "experience": {
    "foundation": "storefront-core",
    "design_tier": "80-point",
    "strategy": "conversion-led-digital-cards",
    "personality": [
      "compact",
      "direct",
      "trustworthy"
    ],
    "guardrails": [
      "Keep checkout, cart, order lookup, and delivery access consistent with the shared storefront.",
      "Prioritize product discovery and delivery confidence before editorial content.",
      "Prefer profile-driven section order and variants before adding one-off page code."
