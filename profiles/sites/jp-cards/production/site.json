      "hero_pattern": "linear-gradient(140deg,#be123c 0%,#be123c 42%,#0f766e 42%,#0f766e 70%,#111827 70%)",
      "featured_limit": 6,
      "announcements": [
        {
          "title": "ゲスト購入に対応",
