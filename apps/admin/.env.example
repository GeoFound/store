MEDUSA_BACKEND_URL=http://localhost:9002
NEXT_PUBLIC_ADMIN_LOCALE=zh-CN
# Comma-separated public origins of this admin app. Required in production when
# the app runs behind a TLS-terminating reverse proxy, where request.url cannot
# be trusted for the same-origin CSRF check. Example:
# ADMIN_TRUSTED_ORIGINS=https://admin.example.com
ADMIN_TRUSTED_ORIGINS=
# Public URL of the built-in Medusa dashboard, for deep-links to surfaces not yet
# migrated to this app (e.g. product pages). Example: https://backend.example.com/app
NEXT_PUBLIC_MEDUSA_ADMIN_URL=http://localhost:9000/app
