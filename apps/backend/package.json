{
  "name": "@dtc/backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:integration": "pnpm run test:integration:http && pnpm run test:integration:modules",
    "test": "pnpm run test:unit && pnpm run test:integration"
  },
  "dependencies": {
    "@medusajs/caching": "2.17.1",
    "@medusajs/caching-redis": "2.17.1",
    "@medusajs/cli": "2.17.1",
    "@medusajs/draft-order": "2.17.1",
    "@medusajs/framework": "2.17.1",
    "@medusajs/medusa": "2.17.1",
    "ioredis": "5.11.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.17.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "jest": "^30.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1"
}
